# Copy this to .env and fill your actual keys. Never commit .env
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# When both LLM keys are set, choose which provider runs first.
# true  = OpenRouter primary, Groq fallback (use while Groq's daily quota is exhausted)
# false = Groq primary, OpenRouter fallback (default once Groq quota resets)
PREFER_OPENROUTER=true
